# Groq Configuration
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=150
GROQ_MAX_RETRIES=0
GROQ_TIMEOUT_SECONDS=8

# Embeddings Configuration
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Vector Store Configuration
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=data/faiss_index

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# API Configuration
ENABLE_CORS=true
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_ONLY_ASK=true

# Session Configuration
AGENT_SESSION_TTL_MINUTES=30
AGENT_MEMORY_MAX_MESSAGES=10
AGENT_FORCE_RAG_MODE=false
AGENT_USE_CHAT_HISTORY=false
AGENT_CONTEXT_HISTORY_MESSAGES=4
AGENT_CONTEXT_DOCS=3
AGENT_MAX_ACTIVE_SESSIONS=1000
AGENT_SESSION_ID_MAX_LENGTH=120
AGENT_MESSAGE_MAX_CHARS=4000
AGENT_MAX_CONTEXT_CHARS=8000
AGENT_SLA_MODE_ENABLED=true
AGENT_LLM_TIMEOUT_SECONDS=2.5
AGENT_FALLBACK_MAX_POINTS=5
AGENT_MAX_CONCURRENT_LLM_REQUESTS=2
AGENT_LLM_MIN_INTERVAL_SECONDS=0.35
AGENT_RATE_LIMIT_COOLDOWN_SECONDS=20
AGENT_CACHE_INCLUDE_FALLBACK=false

# RAG Configuration
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=6
RAG_RELEVANCE_THRESHOLD=0.25
